# ===================================================================
# RUG OR RICHES — Environment Variables
# ===================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# Required for: Railway / Render / Fly.io backend deployment
# ===================================================================

# --- Database (Supabase PostgreSQL) ---
# Get this from Supabase Dashboard → Settings → Database → Connection string (URI tab)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# --- Supabase REST API (for local dev fallback when pg can't connect) ---
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_KEY=sb_secret_XXXXX

# --- Telegram Bot ---
# Get BOT_TOKEN from @BotFather
BOT_TOKEN=123456:ABC-DEF
# Your Telegram channel/group ID or @handle (for announcements)
TG_CHAT_ID=@your_channel

# --- Server ---
PORT=8080

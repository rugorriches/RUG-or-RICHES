{
  "name": "rug-or-riches",
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "*.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/leaderboard", "dest": "/api/leaderboard.js" },
    { "src": "/api/stats", "dest": "/api/stats.js" },
    { "src": "/api/crews", "dest": "/api/crews.js" },
    { "src": "/api/verify", "dest": "/api/verify.js" },
    { "src": "/api/sync", "dest": "/api/sync.js" },
    { "src": "/api/invoice", "dest": "/api/invoice.js" },
    { "src": "/api/webhook", "dest": "/api/webhook.js" },
    { "src": "/api/cashout", "dest": "/api/cashout.js" },
    { "src": "/api/upgrade", "dest": "/api/upgrade.js" },
    { "src": "/api/claim", "dest": "/api/claim.js" },
    { "src": "/api/gift", "dest": "/api/gift.js" },
    { "src": "/api/cron", "dest": "/api/cron.js" },
    { "src": "/play", "dest": "/moontap.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ],
  "crons": [
    { "path": "/api/cron?job=nudge", "schedule": "0 17 * * *" },
    { "path": "/api/cron?job=recap", "schedule": "0 16 * * 1" },
    { "path": "/api/cron?job=payouts", "schedule": "0 15 * * 1" }
  ]
}

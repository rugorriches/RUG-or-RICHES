{
  "name": "rug-or-riches",
  "builds": [
    { "src": "api/main.js", "use": "@vercel/node" },
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "assets/**", "use": "@vercel/static" },
    { "src": "robots.txt", "use": "@vercel/static" },
    { "src": "sitemap.xml", "use": "@vercel/static" },
    { "src": "tonconnect-manifest.json", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/leaderboard", "dest": "/api/main.js?route=leaderboard" },
    { "src": "/api/stats", "dest": "/api/main.js?route=stats" },
    { "src": "/api/crews", "dest": "/api/main.js?route=crews" },
    { "src": "/api/verify", "dest": "/api/main.js?route=verify" },
    { "src": "/api/sync", "dest": "/api/main.js?route=sync" },
    { "src": "/api/invoice", "dest": "/api/main.js?route=invoice" },
    { "src": "/api/webhook", "dest": "/api/main.js?route=webhook" },
    { "src": "/api/cashout", "dest": "/api/main.js?route=cashout" },
    { "src": "/api/upgrade", "dest": "/api/main.js?route=upgrade" },
    { "src": "/api/claim", "dest": "/api/main.js?route=claim" },
    { "src": "/api/daily", "dest": "/api/main.js?route=daily" },
    { "src": "/api/crash", "dest": "/api/main.js?route=crash" },
    { "src": "/api/gift", "dest": "/api/main.js?route=gift" },
    { "src": "/api/cron", "dest": "/api/main.js?route=cron" },
    { "src": "/api/boards", "dest": "/api/main.js?route=boards" },
    { "src": "/api/duel", "dest": "/api/main.js?route=duel" },
    { "src": "/api/admin", "dest": "/api/main.js?route=admin" },
    { "src": "/api/ranked", "dest": "/api/main.js?route=ranked" },
    { "src": "/api/reset", "dest": "/api/main.js?route=reset" },
    { "src": "/favicon.ico", "headers": { "cache-control": "public, max-age=604800" }, "dest": "/assets/brand/favicon.ico" },
    { "src": "/favicon-48x48.png", "headers": { "cache-control": "public, max-age=604800" }, "dest": "/assets/brand/favicon-48x48.png" },
    { "src": "/favicon-96x96.png", "headers": { "cache-control": "public, max-age=604800" }, "dest": "/assets/brand/favicon-96x96.png" },
    { "src": "/apple-touch-icon.png", "headers": { "cache-control": "public, max-age=604800" }, "dest": "/assets/brand/apple-touch-icon.png" },
    { "src": "/android-chrome-192x192.png", "headers": { "cache-control": "public, max-age=604800" }, "dest": "/assets/brand/android-chrome-192x192.png" },
    { "src": "/android-chrome-512x512.png", "headers": { "cache-control": "public, max-age=604800" }, "dest": "/assets/brand/android-chrome-512x512.png" },
    { "src": "/logo-512.png", "headers": { "cache-control": "public, max-age=604800" }, "dest": "/assets/brand/logo-512.png" },
    { "src": "/og-image.png", "headers": { "cache-control": "public, max-age=604800" }, "dest": "/assets/brand/og-image-v2.png" },
    { "src": "/og-image-v2.png", "headers": { "cache-control": "public, max-age=604800" }, "dest": "/assets/brand/og-image-v2.png" },
    { "src": "/tonconnect-manifest.json", "headers": { "Access-Control-Allow-Origin": "*", "cache-control": "public, max-age=600" }, "dest": "/tonconnect-manifest.json" },
    { "src": "/api/tonverify", "dest": "/api/main.js?route=tonverify" },
    { "src": "/api/referrals", "dest": "/api/main.js?route=referrals" },
    { "src": "/play", "headers": { "cache-control": "no-cache, no-store, must-revalidate" }, "dest": "/moontap.html" },
    { "src": "/", "headers": { "cache-control": "no-cache, no-store, must-revalidate" }, "dest": "/index.html" },
    { "src": "/(.*\\.html)", "headers": { "cache-control": "no-cache, no-store, must-revalidate" }, "dest": "/$1" },
    { "src": "/privacy", "dest": "/privacy.html" },
    { "src": "/terms", "dest": "/terms.html" },
    { "src": "/cookies", "dest": "/cookies.html" },
    { "src": "/litepaper", "dest": "/litepaper.html" },
    { "src": "/guide", "dest": "/guide.html" },
    { "src": "/vip", "dest": "/vip.html" },
    { "src": "/referrals", "dest": "/referrals.html" },
    { "src": "/airdrop", "dest": "/airdrop.html" },
    { "src": "/tokenomics", "dest": "/tokenomics.html" },
    { "src": "/faq", "dest": "/faq.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ],
  "crons": [
    { "path": "/api/cron?job=nudge", "schedule": "0 17 * * *" },
    { "path": "/api/cron?job=recap", "schedule": "0 16 * * 1" },
    { "path": "/api/cron?job=payouts", "schedule": "0 15 * * 1" },
    { "path": "/api/cron?job=daily", "schedule": "10 0 * * *" }
  ]
}
